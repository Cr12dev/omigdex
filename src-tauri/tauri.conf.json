{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "omigdex-app",
  "version": "0.1.0",
  "identifier": "com.crist.omigdex-app",
  "build": {
    "beforeDevCommand": "pnpm build",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "omigdex-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English", "Spanish"],
        "installerHooks": "./installer-hooks.nsi"
      }
    }
  }
}
